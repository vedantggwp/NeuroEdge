# Everything ignored by default
*

# Allow PitchDeck
!PitchDeck/
!PitchDeck/**

# Allow video project
!video/
!video/**

# Allow docs
!docs/
!docs/**

# Allow brand kit
!brand/
!brand/**

# Allow git infrastructure
!.gitignore

# Allow top-level MANIFEST + README + CHANGELOG
!MANIFEST.md
!README.md
!CHANGELOG.md

# Ignore build artifacts inside video
video/out/
video/node_modules/
video/.cache/

# Allow Next.js app
!app/
!app/**
app/node_modules/
app/.next/

# Allow scan service
!scan-service/
!scan-service/**
scan-service/node_modules/
scan-service/dist/

# Allow MCP server (open-source, BYO-AI accessibility auditor)
!mcp-server/
!mcp-server/**
mcp-server/node_modules/
mcp-server/dist/

# Allow Supabase
!supabase/
!supabase/**

# Allow GitHub Actions
!.github/
!.github/**

# Environment files (never commit)
**/.env
**/.env.*
!**/.env.example
